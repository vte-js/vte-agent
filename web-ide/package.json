{
  "name": "vte-web-ide",
  "version": "0.1.0",
  "private": true,
  "description": "Second host (Node + browser) for vte-agent — validates host-agnostic architecture. Three-pane web IDE reusing the core agent engine and webview component library.",
  "scripts": {
    "dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "vite build --config client/vite.config.ts",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vue": "^3.5.0"
  }
}
