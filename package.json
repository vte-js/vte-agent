{
  "name": "vte-agent",
  "displayName": "VTE Agent",
  "description": "AI coding agent with opencode-style context management",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vte-agent-sidebar",
          "title": "VTE Agent",
          "icon": "resources/icon.svg"
        },
        {
          "id": "vte-lsp-sidebar",
          "title": "LSP Control",
          "icon": "resources/lsp-icon.svg"
        }
      ]
    },
    "views": {
      "vte-agent-sidebar": [
        {
          "type": "webview",
          "id": "vte-agent.chat",
          "name": "VTE Agent"
        }
      ],
      "vte-lsp-sidebar": [
        {
          "id": "vte-lsp-status",
          "name": "LSP Status"
        }
      ]
    },
    "commands": [
      {
        "command": "vte-agent.newSession",
        "title": "新建会话",
        "icon": "$(add)"
      },
      {
        "command": "vte-agent.openSessions",
        "title": "会话历史",
        "icon": "$(history)"
      },
      {
        "command": "vte-agent.openSkills",
        "title": "Skills 管理",
        "icon": "$(layers)"
      },
      {
        "command": "vte-agent.openConfig",
        "title": "VTE Agent设置",
        "icon": "$(settings-gear)"
      },
      {
        "command": "vte-agent.clearChat",
        "title": "清空对话",
        "icon": "$(trash)"
      },
      {
        "command": "vte-agent.openChat",
        "title": "VTE Agent: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "vteAgent.setupLsp",
        "title": "VTE Agent: Setup LSP",
        "icon": "$(symbol-event)"
      },
      {
        "command": "vte-lsp.openConfigEditor",
        "title": "VTE Agent: Open LSP Config Editor",
        "icon": "$(settings-gear)"
      },
      {
        "command": "vte-lsp.testLsp",
        "title": "LSP: Test at Cursor",
        "icon": "$(debug-alt)"
      },
      {
        "command": "vte-lsp.clearCache",
        "title": "LSP: Clear Cache",
        "icon": "$(trash)"
      },
      {
        "command": "vte-lsp.refreshStatus",
        "title": "LSP: Refresh Status",
        "icon": "$(refresh)"
      },
      {
        "command": "vte-lsp.showStatus",
        "title": "LSP: Show Status Panel"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vte-agent.newSession",
          "when": "view == vte-agent.chat",
          "group": "navigation@1"
        },
        {
          "command": "vte-agent.openSessions",
          "when": "view == vte-agent.chat",
          "group": "navigation@2"
        },
        {
          "command": "vte-agent.openSkills",
          "when": "view == vte-agent.chat",
          "group": "navigation@3"
        },
        {
          "command": "vte-agent.openConfig",
          "when": "view == vte-agent.chat",
          "group": "navigation@4"
        },
        {
          "command": "vte-agent.clearChat",
          "when": "view == vte-agent.chat",
          "group": "navigation@5"
        },
        {
          "command": "vte-lsp.openConfigEditor",
          "when": "view == vte-lsp-status",
          "group": "navigation@1"
        },
        {
          "command": "vte-lsp.testLsp",
          "when": "view == vte-lsp-status",
          "group": "navigation@2"
        },
        {
          "command": "vte-lsp.clearCache",
          "when": "view == vte-lsp-status",
          "group": "navigation@3"
        },
        {
          "command": "vte-lsp.refreshStatus",
          "when": "view == vte-lsp-status",
          "group": "navigation@4"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.github/agent-lsp.json",
        "url": "./schemas/agent-lsp.schema.json"
      }
    ],
    "configuration": {
      "title": "VTE Agent",
      "properties": {
        "vteCode.apiKey": {
          "type": "string",
          "default": "",
          "description": "LLM API key"
        },
        "vteCode.apiBase": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "LLM API base URL"
        },
        "vteCode.model": {
          "type": "string",
          "default": "gpt-4",
          "description": "Model name"
        },
        "vteCode.models": {
          "type": "array",
          "default": [
            {
              "name": "MiMo v2.5",
              "apiKey": "",
              "apiBase": "https://api.xiaomimimo.com/v1",
              "model": "mimo-v2.5"
            }
          ],
          "description": "Model profiles. Each profile: { name, apiKey, apiBase, model }. The wire protocol (Chat Completions vs OpenAI Responses API) and thinking style are auto-inferred from the base URL + model name — no manual setup needed. To override the protocol explicitly, use the built-in model settings UI (gear icon) where an 'API 协议' selector is available. Leave this raw list for advanced JSON editing only.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "apiKey": { "type": "string" },
              "apiBase": { "type": "string" },
              "model": { "type": "string" }
            }
          }
        },
        "vteCode.activeModelIndex": {
          "type": "number",
          "default": 0,
          "description": "Active model profile index"
        },
        "vteAgent.lsp.profiles": {
          "type": "object",
          "default": {},
          "description": "LSP profiles configuration for each language",
          "properties": {
            "typescript": {
              "type": "object",
              "properties": {
                "tools": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["definition", "references", "hover", "documentSymbol"]
                  },
                  "default": ["definition", "references", "hover", "documentSymbol"]
                },
                "strategy": {
                  "type": "string",
                  "enum": ["builtin", "direct"],
                  "default": "builtin"
                },
                "fileExtensions": {
                  "type": "array",
                  "items": { "type": "string" },
                  "default": [".ts", ".tsx"]
                },
                "timeoutMs": {
                  "type": "number",
                  "default": 5000
                }
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy:assets && npm run build:webview",
    "compile": "tsc -p ./",
    "copy:assets": "cp src/agent/default-rules.md out/agent/default-rules.md 2>/dev/null || true",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview && npx vite build",
    "dev:webview": "cd webview && npx vite"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.2"
  }
}
