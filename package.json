{
  "name": "vte-agent",
  "displayName": "VTE Agent",
  "description": "AI coding agent with opencode-style context management",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vte-agent-sidebar",
          "title": "VTE Agent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vte-agent-sidebar": [
        {
          "type": "webview",
          "id": "vte-agent.chat",
          "name": "VTE Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "vte-agent.openChat",
        "title": "VTE Agent: Open Chat",
        "icon": "$(comment-discussion)"
      }
    ],
    "configuration": {
      "title": "VTE Agent",
      "properties": {
        "vteCode.apiKey": {
          "type": "string",
          "default": "",
          "description": "LLM API key"
        },
        "vteCode.apiBase": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "LLM API base URL"
        },
        "vteCode.model": {
          "type": "string",
          "default": "gpt-4",
          "description": "Model name"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy:assets && npm run build:webview",
    "compile": "tsc -p ./",
    "copy:assets": "cp src/agent/default-rules.md out/agent/default-rules.md 2>/dev/null || true",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd webview && npx vite build",
    "dev:webview": "cd webview && npx vite"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.2"
  }
}
